## OPAQUE objects
```cpp
namespace
{
    struct opaque_instance;
    struct opaque_device;
    struct opaque_phisical_device;
}

namespace ktl::api
{
    using ptr_instance = opaque_instance *;
    using ptr_device = opaque_device *;
    using ptr_phisical_device = opaque_phisical_device *;
}
```

